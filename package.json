{
  "name": "muzykant-soundcloud-downloader",
  "version": "2.9.0",
  "description": "Download Soundcloud audio with Node.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./index.d.ts"
    }
  },
  "scripts": {
    "docs": "typedoc && mkdir -p ./docs && touch ./docs/.nojekyll",
    "build": "pnpm exec tsdown --dts && pnpm run build:types",
    "publish-script": "./publish.sh",
    "test": "jest --runInBand",
    "sc:token": "node ./scripts/generate-client-id.cjs",
    "test:integration": "RUN_INTEGRATION_TESTS=true jest --runInBand",
    "test:ci": "jest --runInBand",
    "lint": "eslint . --ext .js,.ts",
    "pretest": "pnpm run build",
    "build:types": "node ./scripts/build-types.cjs"
  },
  "keywords": [
    "soundcloud",
    "soundcloud-api",
    "soundcloud downloader",
    "soundcloud download",
    "soundcloud audio",
    "download soundcloud",
    "scdl"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Muzykant-Team/node-soundcloud-downloader.git"
  },
  "author": "Zack Radisic",
  "maintainers": [
    "Muzykant Team"
  ],
  "contributors": [
    "Muzykant Team"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=24.18.0"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "m3u8stream": "^0.8.6",
    "soundcloud-key-fetch": "^1.0.13",
    "tsdown": "^0.22.4"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.5",
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@farmfe/core": "^1.7.11",
    "@farmfe/runtime": "^0.12.10",
    "@rspack/core": "^1.7.12",
    "@types/koa__cors": "^5.0.1",
    "@types/webpack": "^5.28.5",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "axios-mock-adapter": "^2.1.0",
    "babel-jest": "^30.4.1",
    "babel-watch": "^7.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-n": "^18.0.0",
    "eslint-plugin-promise": "^7.3.0",
    "file-type": "^21.3.4",
    "jest": "^30.4.2",
    "music-metadata": "^11.13.0",
    "pkg-types": "^2.3.1",
    "publint": "^0.3.21",
    "typedoc": "^0.28.20",
    "typescript": "^5.9.3",
    "unloader": "^0.9.0",
    "unplugin-unused": "^0.5.7",
    "vitest": "^4.1.10",
    "webpack": "^5.108.4"
  }
}
